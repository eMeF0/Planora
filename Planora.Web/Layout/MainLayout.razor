@inherits LayoutComponentBase
@inject NavigationManager NavigationManager

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main class="app-main">
        <div class="top-row">
            <div class="page-heading">
                <span class="eyebrow">Obszar pracy</span>
                <h1>@PageTitle</h1>
            </div>

            <label class="global-search">
                <span class="search-icon" aria-hidden="true"></span>
                <input type="search" placeholder="Szukaj zadań, projektów i notatek" aria-label="Szukaj zadań, projektów i notatek" />
            </label>
        </div>

        <article class="content">
            @Body
        </article>
    </main>
</div>

@code {
    private string PageTitle
    {
        get
        {
            var path = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).Trim('/').ToLowerInvariant();

            if (path.StartsWith("projects/create"))
            {
                return "Nowy projekt";
            }

            if (path.StartsWith("projects/"))
            {
                return "Szczegóły projektu";
            }

            if (path.StartsWith("tasks/create"))
            {
                return "Nowe zadanie";
            }

            if (path.StartsWith("ideas/create"))
            {
                return "Nowy pomysł";
            }

            if (path.StartsWith("links/create"))
            {
                return "Nowy link";
            }

            if (path.StartsWith("notes/create"))
            {
                return "Nowa notatka";
            }

            if (path.StartsWith("projects"))
            {
                return "Projekty";
            }

            if (path.StartsWith("calendar"))
            {
                return "Kalendarz";
            }

            if (path.StartsWith("analytics"))
            {
                return "Analityka";
            }

            return "Panel";
        }
    }
}
