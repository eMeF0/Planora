@page "/notes/create/{Id:guid}"
@using Planora.Web.Models.DTOs.Note
@inject NavigationManager NavigationManager
@inject HttpClient Http

<section class="form-layout">
    <div class="form-intro">
        <span class="section-kicker">Notatka</span>
        <h2>Dodaj kontekst projektu</h2>
        <p>Zapisz decyzje, notatki ze spotkań i ważne informacje obok bieżącej pracy.</p>
    </div>

    <EditForm Model="newNote" OnValidSubmit="CreateNewNote" class="form-card">
        <DataAnnotationsValidator />
        <div class="form-grid">
            <label class="input-control">
                <span>Treść notatki</span>
                <InputTextArea @bind-Value="newNote.Content" placeholder="Decyzja, podsumowanie rozmowy albo przypomnienie" rows="7" />
                <ValidationMessage For="@(() => newNote.Content)" />
            </label>
        </div>

        <div class="form-actions">
            <a class="btn btn-secondary" href="@($"/projects/{Id}")">Anuluj</a>
            <button class="btn btn-primary" type="submit">Zapisz notatkę</button>
        </div>
    </EditForm>
</section>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private CreateNoteDto newNote = new();

    private async Task CreateNewNote()
    {
        var response = await Http.PostAsJsonAsync($"api/note/{Id}", newNote);

        if (response.IsSuccessStatusCode)
        {
            NavigationManager.NavigateTo($"/projects/{Id}");
        }
    }
}
