@page "/projects/create"
@using Planora.Web.Models.DTOs.Project
@inject NavigationManager NavigationManager
@inject HttpClient Http

<section class="form-layout">
    <div class="form-intro">
        <span class="section-kicker">Nowy projekt</span>
        <h2>Utwórz uporządkowany obszar pracy</h2>
        <p>Dodaj projekt z jasną nazwą, przydatnym kontekstem i opcjonalnym terminem do planowania.</p>
    </div>

    <EditForm Model="newProject" OnValidSubmit="CreateNewProject" class="form-card">
        <DataAnnotationsValidator />
        <div class="form-grid">
            <label class="input-control">
                <span>Nazwa projektu</span>
                <InputText @bind-Value="newProject.Name" placeholder="Przebudowa strony" />
                <ValidationMessage For="@(() => newProject.Name)" />
            </label>

            <label class="input-control">
                <span>Opis</span>
                <InputTextArea @bind-Value="newProject.Description" placeholder="Zakres, cele, interesariusze" rows="5" />
                <ValidationMessage For="@(() => newProject.Description)" />
            </label>

            <label class="input-control">
                <span>Termin</span>
                <input type="date" @bind="selectedDeadline" />
            </label>
        </div>

        <div class="form-actions">
            <a class="btn btn-secondary" href="/projects">Anuluj</a>
            <button class="btn btn-primary" type="submit">Utwórz projekt</button>
        </div>
    </EditForm>
</section>

@code{
    private CreateProjectDto newProject = new CreateProjectDto();
    private DateTime? selectedDeadline;

    private async Task CreateNewProject()
    {
        if (selectedDeadline.HasValue)
        {
            newProject.Deadline = new DateTimeOffset(selectedDeadline.Value, TimeSpan.Zero);
        }

        var response = await Http.PostAsJsonAsync("api/project", newProject);
        if (response.IsSuccessStatusCode)
        {
            NavigationManager.NavigateTo("/projects");
        }
    }
}
