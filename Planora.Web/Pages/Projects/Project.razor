@page "/projects/{Id:guid}"
@using MudBlazor
@using Planora.Web.Models.DTOs
@using System.Net.Http.Json
@using Planora.Web.Models.DTOs.Project
@using Microsoft.AspNetCore.Components
@inject HttpClient Http

@if (project == null)
{
    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudText Typo="Typo.h4">
        @project.Name
    </MudText>

    <MudText>
        @project.Description
    </MudText>

    <MudChip T="string" Color="Color.Success">
        @project.Status.ToString()
    </MudChip>
}


@code {
    [Parameter]
    public Guid Id { get; set; }
    private ProjectDetailDto? project;

    protected override async Task OnInitializedAsync()
    {
        project = await Http.GetFromJsonAsync<ProjectDetailDto>($"api/project/{Id}");
    }
}
