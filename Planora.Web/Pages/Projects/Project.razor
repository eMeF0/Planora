@page "/projects/{Id:guid}"
@using Planora.Web.Models.DTOs
@using System.Net.Http.Json
@using Planora.Web.Models.DTOs.Project
@using Microsoft.AspNetCore.Components

@inject HttpClient Http

@if (!string.IsNullOrWhiteSpace(loadError))
{
    <div class="empty-state">@loadError</div>
}
else if (project != null)
{
    <section class="project-hero">
        <div>
            <span class="status-badge @StatusClass(project.Status)">@StatusLabel(project.Status)</span>
            <h2>@project.Name</h2>
            <p>@(string.IsNullOrWhiteSpace(project.Description) ? "Nie dodano jeszcze opisu projektu." : project.Description)</p>
        </div>
        <div class="hero-actions">
            <a class="btn btn-secondary" href="/projects">Wróć do projektów</a>
            <a class="btn btn-primary" href="@($"/tasks/create/{Id}")">Utwórz zadanie</a>
        </div>
    </section>

    <nav class="module-tabs" aria-label="Sekcje projektu">
        @foreach (var tab in ProjectTabs)
        {
            <button class="module-tab @(activeTab == tab ? "is-active" : string.Empty)" type="button" @onclick="() => activeTab = tab">@tab</button>
        }
    </nav>

    @if (activeTab == "Przegląd")
    {
        <section class="content-grid">
            <div class="panel panel-large">
                <div class="panel-header">
                    <div>
                        <span class="section-kicker">Przegląd</span>
                        <h2>Obraz projektu</h2>
                    </div>
                </div>
                <div class="stats-grid compact-stats">
                    <div class="metric-card">
                        <span>Zadania</span>
                        <strong>@project.Tasks.Count</strong>
                        <small>Ukończone: @CompletedTaskCount</small>
                    </div>
                    <div class="metric-card">
                        <span>Pomysły</span>
                        <strong>@project.Ideas.Count</strong>
                        <small>Zapisane do przeglądu</small>
                    </div>
                    <div class="metric-card">
                        <span>Zasoby</span>
                        <strong>@project.Links.Count</strong>
                        <small>Podłączone linki</small>
                    </div>
                    <div class="metric-card">
                        <span>Termin</span>
                        <strong>@DeadlineMetric</strong>
                        <small>@DeadlineSubtext</small>
                    </div>
                </div>
                <div class="project-summary-block">
                    <h3>Cel</h3>
                    <p>@(string.IsNullOrWhiteSpace(project.Description) ? "Dodaj opis projektu w ustawieniach, aby doprecyzować zakres i oczekiwane rezultaty." : project.Description)</p>
                </div>
            </div>

            <aside class="side-column">
                <div class="panel">
                    <div class="panel-header simple">
                        <div>
                            <span class="section-kicker">Wiedza</span>
                            <h2>Ostatnie notatki</h2>
                        </div>
                    </div>
                    <div class="activity-list">
                        @foreach (var note in project.Notes.OrderByDescending(note => note.CreatedAt).Take(4))
                        {
                            <div class="activity-row">
                                <span class="activity-dot warning"></span>
                                <span>
                                    <strong>Notatka</strong>
                                    <small>@note.Content</small>
                                </span>
                            </div>
                        }
                        @if (!project.Notes.Any())
                        {
                            <div class="empty-state compact">Brak notatek.</div>
                        }
                    </div>
                </div>
            </aside>
        </section>
    }
    else if (activeTab == "Zadania")
    {
        <section class="panel panel-large">
            <div class="panel-header">
                <div>
                    <span class="section-kicker">Zadania projektu</span>
                    <h2>Zadania projektu</h2>
                </div>
                <div class="toolbar">
                    <label class="input-control compact">
                        <span>Szukaj</span>
                        <input type="search" placeholder="Znajdź zadanie" @bind="taskSearch" @bind:event="oninput" />
                    </label>
                    <select class="select-control" @bind="taskFilter" aria-label="Filtruj zadania">
                        <option value="All">Wszystkie</option>
                        <option value="Open">Otwarte</option>
                        <option value="Done">Ukończone</option>
                    </select>
                    <a class="btn btn-primary" href="@($"/tasks/create/{Id}")">Dodaj zadanie</a>
                </div>
            </div>

            <div class="task-list">
                @foreach (var task in FilteredTasks)
                {
                    <article class="task-card">
                        <div class="task-checkbox @(task.IsCompleted ? "is-complete" : string.Empty)" aria-hidden="true"></div>
                        <div class="task-content">
                            <div class="task-title-row">
                                <h3>@task.Title</h3>
                                <span class="priority-pill @PriorityClass(task.Deadline)">@PriorityLabel(task.Deadline)</span>
                            </div>
                            <p>@(string.IsNullOrWhiteSpace(task.Description) ? "Brak opisu." : task.Description)</p>
                            <div class="task-meta">
                                <span>@FormatDate(task.Deadline)</span>
                                <span>@(task.IsCompleted ? "Ukończone" : "W toku")</span>
                            </div>
                        </div>
                    </article>
                }
                @if (!FilteredTasks.Any())
                {
                    <div class="empty-state">Żadne zadania nie pasują do wybranych filtrów.</div>
                }
            </div>
        </section>
    }
    else if (activeTab == "Członkowie")
    {
        <section class="panel panel-large">
            <div class="panel-header">
                <div>
                    <span class="section-kicker">Członkowie</span>
                    <h2>Członkowie projektu</h2>
                </div>
            </div>
            <div class="member-grid">
                <div class="member-card">
                    <span class="profile-avatar">M</span>
                    <div>
                        <strong>Mateusz</strong>
                        <small>Właściciel</small>
                    </div>
                </div>
                <div class="member-card">
                    <span class="profile-avatar muted-avatar">PM</span>
                    <div>
                        <strong>Kierownik projektu</strong>
                        <small>Planowanie</small>
                    </div>
                </div>
                <div class="member-card">
                    <span class="profile-avatar muted-avatar">FE</span>
                    <div>
                        <strong>Frontend</strong>
                        <small>Realizacja</small>
                    </div>
                </div>
            </div>
        </section>
    }
    else if (activeTab == "Statystyki")
    {
        <section class="content-grid">
            <div class="panel panel-large">
                <div class="panel-header">
                    <div>
                        <span class="section-kicker">Statystyki</span>
                        <h2>Statystyki projektu</h2>
                    </div>
                </div>
                <div class="productivity-chart large-chart" aria-label="Wykres produktywności projektu">
                    @foreach (var value in ProjectVelocity)
                    {
                        <span style="height: @value%"></span>
                    }
                </div>
            </div>
            <aside class="side-column">
                <div class="panel">
                    <div class="insight-grid compact-insights">
                        <div class="insight-row">
                            <span>Ukończenie</span>
                            <strong>@ProjectCompletion%</strong>
                        </div>
                        <div class="insight-row">
                            <span>Otwarte zadania</span>
                            <strong>@OpenTaskCount</strong>
                        </div>
                    </div>
                </div>
            </aside>
        </section>
    }
    else if (activeTab == "Ustawienia")
    {
        <section class="panel panel-large">
            <div class="panel-header">
                <div>
                    <span class="section-kicker">Ustawienia</span>
                    <h2>Ustawienia projektu</h2>
                </div>
                <a class="btn btn-secondary" href="/projects">Zarządzaj w projektach</a>
            </div>
            <div class="settings-list">
                <div class="settings-row">
                    <span>
                        <strong>Tożsamość projektu</strong>
                        <small>Nazwa, opis, status i termin są zarządzane w module projektów.</small>
                    </span>
                </div>
                <div class="settings-row danger-settings">
                    <span>
                        <strong>Strefa ryzyka</strong>
                        <small>Usuwanie jest celowo dostępne w module projektów, aby ograniczyć przypadkowe skasowanie danych.</small>
                    </span>
                </div>
            </div>
        </section>
    }
}
else
{
    <div class="empty-state">Ładowanie projektu...</div>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private readonly string[] ProjectTabs = { "Przegląd", "Zadania", "Członkowie", "Statystyki", "Ustawienia" };
    private ProjectDetailDto? project;
    private string taskSearch = string.Empty;
    private string taskFilter = "All";
    private string activeTab = "Przegląd";
    private string? loadError;

    private int CompletedTaskCount => project?.Tasks.Count(task => task.IsCompleted) ?? 0;
    private int OpenTaskCount => project?.Tasks.Count(task => !task.IsCompleted) ?? 0;
    private int ProjectCompletion => project is null || project.Tasks.Count == 0 ? 0 : (int)Math.Round(CompletedTaskCount * 100.0 / project.Tasks.Count);
    private string DeadlineMetric => project?.Deadline.HasValue == true ? project.Deadline.Value.LocalDateTime.ToString("dd MMM") : "Brak";
    private string DeadlineSubtext => project?.Deadline.HasValue == true ? project.Deadline.Value.LocalDateTime.ToString("yyyy") : "Nie wybrano daty";
    private int[] ProjectVelocity => new[] { 34, 48, 56, 44, 70, 78, 66 };

    private IEnumerable<Planora.Web.Models.DTOs.Task.ProjectTaskDto> FilteredTasks => (project?.Tasks ?? Enumerable.Empty<Planora.Web.Models.DTOs.Task.ProjectTaskDto>())
        .Where(task => string.IsNullOrWhiteSpace(taskSearch)
            || task.Title.Contains(taskSearch, StringComparison.OrdinalIgnoreCase)
            || (task.Description?.Contains(taskSearch, StringComparison.OrdinalIgnoreCase) ?? false))
        .Where(task => taskFilter == "All" || (taskFilter == "Done" && task.IsCompleted) || (taskFilter == "Open" && !task.IsCompleted))
        .OrderBy(task => task.IsCompleted)
        .ThenBy(task => task.Deadline ?? DateTimeOffset.MaxValue);

    protected override async System.Threading.Tasks.Task OnInitializedAsync()
    {
        try
        {
            project = await Http.GetFromJsonAsync<ProjectDetailDto>($"api/project/{Id}");
        }
        catch (Exception)
        {
            loadError = "Nie udało się załadować szczegółów projektu. Sprawdź, czy Planora API i baza danych działają.";
        }
    }

    private static string StatusClass(ProjectStatus status)
    {
        return status switch
        {
            ProjectStatus.Active => "status-active",
            ProjectStatus.Completed => "status-completed",
            ProjectStatus.Inactive => "status-inactive",
            ProjectStatus.Archived => "status-archived",
            _ => "status-inactive"
        };
    }

    private static string FormatDate(DateTimeOffset? date)
    {
        return date.HasValue ? $"Termin: {date.Value.LocalDateTime:dd MMM yyyy}" : "Brak terminu";
    }

    private static string PriorityLabel(DateTimeOffset? deadline)
    {
        if (!deadline.HasValue)
        {
            return "Normalny";
        }

        var days = (deadline.Value.LocalDateTime.Date - DateTime.Now.Date).TotalDays;
        return days <= 2 ? "Wysoki" : days <= 7 ? "Średni" : "Normalny";
    }

    private static string StatusLabel(ProjectStatus status)
    {
        return status switch
        {
            ProjectStatus.Active => "Aktywny",
            ProjectStatus.Completed => "Ukończony",
            ProjectStatus.Inactive => "Nieaktywny",
            ProjectStatus.Archived => "Archiwalny",
            _ => "Nieaktywny"
        };
    }

    private static string PriorityClass(DateTimeOffset? deadline)
    {
        if (!deadline.HasValue)
        {
            return "priority-normal";
        }

        var days = (deadline.Value.LocalDateTime.Date - DateTime.Now.Date).TotalDays;
        return days <= 2 ? "priority-high" : days <= 7 ? "priority-medium" : "priority-normal";
    }
}
