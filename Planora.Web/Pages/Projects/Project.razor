@page "/projects/{Id:guid}"
@using MudBlazor
@using Planora.Web.Models.DTOs
@using System.Net.Http.Json
@using Planora.Web.Models.DTOs.Project
@using Microsoft.AspNetCore.Components

@inject HttpClient Http
<MudButtonGroup Color="Color.Primary" Variant="Variant.Filled">
    <MudButton Href="@($"/tasks/create/{Id}")">Create Task</MudButton>
    <MudButton Href="@($"/ideas/create/{Id}")">Create Idea</MudButton>
    <MudButton Href="@($"/links/create/{Id}")">Create Link</MudButton>
    <MudButton Href="@($"/notes/create/{Id}")">Create Note</MudButton>
</MudButtonGroup>

@if (project != null)
{
    <MudPaper Class="pa-4 mt-4">
        <MudText Typo="Typo.h4">@project.Name</MudText>
        <MudText Typo="Typo.subtitle1">@project.Description</MudText>
        @if (project.Deadline.HasValue)
        {
            <MudText Typo="Typo.subtitle2">Deadline: @project.Deadline.Value.LocalDateTime.ToShortDateString()</MudText>
        }
    </MudPaper>

    <MudTabs Class="mt-4">
        <MudTabPanel Text="Tasks">
            <MudList T="object">
                @foreach (var task in project.Tasks)
                {
                    <MudListItem T="object">@task.Title</MudListItem>
                }
            </MudList>
        </MudTabPanel>
        <MudTabPanel Text="Ideas">
            <MudList T="object">
                @foreach (var idea in project.Ideas)
                {
                    <MudListItem T="object">@idea.Title</MudListItem>
                }
            </MudList>
        </MudTabPanel>
        <MudTabPanel Text="Links">
            <MudList T="object">
                @foreach (var link in project.Links)
                {
                    <MudListItem T="object"><a href="@link.Url" target="_blank">@link.Description</a></MudListItem>
                }
            </MudList>
        </MudTabPanel>
        <MudTabPanel Text="Notes">
            <MudList T="object">
                @foreach (var note in project.Notes)
                {
                    <MudListItem T="object">@note.Content</MudListItem>
                }
            </MudList>
        </MudTabPanel>
    </MudTabs>
}
else
{
    <p>Loading...</p>
}

@code {
    [Parameter]
    public Guid Id { get; set; }
    private ProjectDetailDto? project;
    protected override async Task OnInitializedAsync()
    {
        project = await Http.GetFromJsonAsync<ProjectDetailDto>($"api/project/{Id}");
    }
}
