@page "/projects"
@using Planora.Web.Models.DTOs
@using Planora.Web.Models.DTOs.Project
@using System.Net.Http.Json
@inject HttpClient Http

<section class="project-hero">
    <div>
        <span class="section-kicker">Projekty</span>
        <h2>Zarządzanie projektami</h2>
        <p>Twórz, wyszukuj, filtruj, edytuj i usuwaj projekty w dedykowanym obszarze Planora.</p>
    </div>
    <div class="hero-actions">
        <a class="btn btn-primary" href="/projects/create">Utwórz projekt</a>
    </div>
</section>

<section class="management-grid">
    <div class="panel panel-large">
        <div class="panel-header">
            <div>
                <span class="section-kicker">Zarządzanie</span>
                <h2>Lista projektów</h2>
            </div>
            <div class="toolbar">
                <label class="input-control compact">
                    <span>Szukaj</span>
                    <input type="search" placeholder="Znajdź projekt" @bind="searchTerm" @bind:event="oninput" />
                </label>
                <select class="select-control" @bind="statusFilter" aria-label="Filtruj projekty według statusu">
                    <option value="All">Wszystkie</option>
                    <option value="Active">Aktywne</option>
                    <option value="Completed">Ukończone</option>
                    <option value="Inactive">Nieaktywne</option>
                    <option value="Archived">Archiwalne</option>
                </select>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(loadError))
        {
            <div class="empty-state">@loadError</div>
        }
        else if (projects is null)
        {
            <div class="empty-state">Ładowanie projektów...</div>
        }
        else if (!FilteredProjects.Any())
        {
            <div class="empty-state">Żaden projekt nie pasuje do wybranych filtrów.</div>
        }
        else
        {
            <div class="management-table" role="table" aria-label="Tabela zarządzania projektami">
                <div class="management-row table-head" role="row">
                    <span role="columnheader">Projekt</span>
                    <span role="columnheader">Status</span>
                    <span role="columnheader">Termin</span>
                    <span role="columnheader">Akcje</span>
                </div>
                @foreach (var project in FilteredProjects)
                {
                    <div class="management-row" role="row">
                        <span class="project-cell" role="cell">
                            <strong>@project.Name</strong>
                            <small>@(string.IsNullOrWhiteSpace(project.Description) ? "Brak opisu." : project.Description)</small>
                        </span>
                        <span role="cell">
                            <span class="status-badge @StatusClass(project.Status)">@StatusLabel(project.Status)</span>
                        </span>
                        <span class="due-date" role="cell">@FormatDeadline(project.Deadline)</span>
                        <span class="row-actions" role="cell">
                            <a class="icon-button" href="@($"/projects/{project.Id}")" aria-label="Otwórz projekt">Otwórz</a>
                            <button class="icon-button" type="button" @onclick="() => BeginEdit(project)">Edytuj</button>
                            <button class="icon-button danger-action" type="button" @onclick="() => RequestDelete(project)">Usuń</button>
                        </span>
                    </div>
                }
            </div>
        }
    </div>

    <aside class="side-column">
        @if (editingProject is not null)
        {
            <div class="panel">
                <div class="panel-header simple">
                    <div>
                        <span class="section-kicker">Edycja</span>
                        <h2>Edytuj projekt</h2>
                    </div>
                </div>

                <EditForm Model="editModel" OnValidSubmit="SaveEdit" class="compact-form">
                    <DataAnnotationsValidator />
                    <label class="input-control">
                        <span>Nazwa</span>
                        <InputText @bind-Value="editModel.Name" />
                    </label>
                    <label class="input-control">
                        <span>Opis</span>
                        <InputTextArea @bind-Value="editModel.Description" rows="4" />
                    </label>
                    <label class="input-control">
                        <span>Status</span>
                        <InputSelect @bind-Value="editModel.Status">
                            <option value="@ProjectStatus.Active">Aktywny</option>
                            <option value="@ProjectStatus.Completed">Ukończony</option>
                            <option value="@ProjectStatus.Inactive">Nieaktywny</option>
                            <option value="@ProjectStatus.Archived">Archiwalny</option>
                        </InputSelect>
                    </label>
                    <label class="input-control">
                        <span>Termin</span>
                        <input type="date" @bind="editDeadline" />
                    </label>

                    <div class="form-actions compact-actions">
                        <button class="btn btn-secondary" type="button" @onclick="CancelEdit">Anuluj</button>
                        <button class="btn btn-primary" type="submit">Zapisz zmiany</button>
                    </div>
                </EditForm>
            </div>
        }

        @if (deleteCandidate is not null)
        {
            <div class="panel danger-panel">
                <div class="panel-header simple">
                    <div>
                        <span class="section-kicker">Usuwanie</span>
                        <h2>Usuń projekt</h2>
                    </div>
                </div>
                <p class="panel-copy">Usunąć <strong>@deleteCandidate.Name</strong>? Projekt zniknie z obszaru pracy.</p>
                <div class="form-actions compact-actions">
                    <button class="btn btn-secondary" type="button" @onclick="CancelDelete">Anuluj</button>
                    <button class="btn btn-danger" type="button" @onclick="DeleteProject">Usuń</button>
                </div>
            </div>
        }

        <div class="panel">
            <div class="panel-header simple">
                <div>
                    <span class="section-kicker">Podsumowanie</span>
                    <h2>Portfel</h2>
                </div>
            </div>
            <div class="insight-grid compact-insights">
                <div class="insight-row">
                    <span>Razem</span>
                    <strong>@ProjectItems.Count()</strong>
                </div>
                <div class="insight-row">
                    <span>Aktywne</span>
                    <strong>@ProjectItems.Count(project => project.Status == ProjectStatus.Active)</strong>
                </div>
                <div class="insight-row">
                    <span>Ukończone</span>
                    <strong>@ProjectItems.Count(project => project.Status == ProjectStatus.Completed)</strong>
                </div>
            </div>
        </div>
    </aside>
</section>

@code {
    private List<ProjectSummaryDto>? projects;
    private string searchTerm = string.Empty;
    private string statusFilter = "All";
    private string? loadError;
    private ProjectSummaryDto? editingProject;
    private ProjectSummaryDto? deleteCandidate;
    private UpdateProjectDto editModel = new();
    private DateTime? editDeadline;

    private IEnumerable<ProjectSummaryDto> ProjectItems => projects ?? Enumerable.Empty<ProjectSummaryDto>();

    private IEnumerable<ProjectSummaryDto> FilteredProjects => ProjectItems
        .Where(project => string.IsNullOrWhiteSpace(searchTerm)
            || project.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)
            || (project.Description?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
        .Where(project => statusFilter == "All" || project.Status.ToString() == statusFilter)
        .OrderBy(project => project.Deadline ?? DateTimeOffset.MaxValue);

    protected override async System.Threading.Tasks.Task OnInitializedAsync()
    {
        await LoadProjects();
    }

    private async System.Threading.Tasks.Task LoadProjects()
    {
        try
        {
            projects = await Http.GetFromJsonAsync<List<ProjectSummaryDto>>("api/project");
            loadError = null;
        }
        catch (Exception)
        {
            loadError = "Nie udało się załadować projektów. Sprawdź, czy Planora API i baza danych działają.";
            projects = new List<ProjectSummaryDto>();
        }
    }

    private void BeginEdit(ProjectSummaryDto project)
    {
        editingProject = project;
        deleteCandidate = null;
        editModel = new UpdateProjectDto
        {
            Id = project.Id,
            Name = project.Name,
            Description = project.Description,
            Deadline = project.Deadline,
            Status = project.Status
        };
        editDeadline = project.Deadline?.LocalDateTime.Date;
    }

    private void CancelEdit()
    {
        editingProject = null;
        editModel = new UpdateProjectDto();
        editDeadline = null;
    }

    private async System.Threading.Tasks.Task SaveEdit()
    {
        if (editingProject is null)
        {
            return;
        }

        editModel.Deadline = editDeadline.HasValue ? new DateTimeOffset(editDeadline.Value, TimeSpan.Zero) : null;
        var response = await Http.PutAsJsonAsync($"api/project/{editingProject.Id}", editModel);

        if (response.IsSuccessStatusCode)
        {
            CancelEdit();
            await LoadProjects();
        }
        else
        {
            loadError = "Nie udało się zaktualizować projektu.";
        }
    }

    private void RequestDelete(ProjectSummaryDto project)
    {
        deleteCandidate = project;
        editingProject = null;
    }

    private void CancelDelete()
    {
        deleteCandidate = null;
    }

    private async System.Threading.Tasks.Task DeleteProject()
    {
        if (deleteCandidate is null)
        {
            return;
        }

        var response = await Http.DeleteAsync($"api/project/{deleteCandidate.Id}");

        if (response.IsSuccessStatusCode)
        {
            deleteCandidate = null;
            await LoadProjects();
        }
        else
        {
            loadError = "Nie udało się usunąć projektu.";
        }
    }

    private static string FormatDeadline(DateTimeOffset? deadline)
    {
        return deadline.HasValue ? deadline.Value.LocalDateTime.ToString("dd MMM yyyy") : "Brak terminu";
    }

    private static string StatusLabel(ProjectStatus status)
    {
        return status switch
        {
            ProjectStatus.Active => "Aktywny",
            ProjectStatus.Completed => "Ukończony",
            ProjectStatus.Inactive => "Nieaktywny",
            ProjectStatus.Archived => "Archiwalny",
            _ => "Nieaktywny"
        };
    }

    private static string StatusClass(ProjectStatus status)
    {
        return status switch
        {
            ProjectStatus.Active => "status-active",
            ProjectStatus.Completed => "status-completed",
            ProjectStatus.Inactive => "status-inactive",
            ProjectStatus.Archived => "status-archived",
            _ => "status-inactive"
        };
    }
}
