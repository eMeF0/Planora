@page "/links/create/{Id:guid}"
@using Planora.Web.Models.DTOs.Link
@inject NavigationManager NavigationManager
@inject HttpClient Http

<section class="form-layout">
    <div class="form-intro">
        <span class="section-kicker">Zasób</span>
        <h2>Dodaj przydatny link</h2>
        <p>Podłącz specyfikacje, materiały, zgłoszenia lub dokumenty, żeby projekt pozostał uporządkowany.</p>
    </div>

    <EditForm Model="newLink" OnValidSubmit="CreateNewLink" class="form-card">
        <DataAnnotationsValidator />
        <div class="form-grid">
            <label class="input-control">
                <span>Tytuł linku</span>
                <InputText @bind-Value="newLink.Description" placeholder="Opis produktu" />
                <ValidationMessage For="@(() => newLink.Description)" />
            </label>

            <label class="input-control">
                <span>URL</span>
                <InputText @bind-Value="newLink.Url" placeholder="https://example.com/spec" />
                <ValidationMessage For="@(() => newLink.Url)" />
            </label>
        </div>

        <div class="form-actions">
            <a class="btn btn-secondary" href="@($"/projects/{Id}")">Anuluj</a>
            <button class="btn btn-primary" type="submit">Dodaj link</button>
        </div>
    </EditForm>
</section>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private CreateLinkDto newLink = new();

    private async Task CreateNewLink()
    {
        var response = await Http.PostAsJsonAsync($"api/projects/{Id}/links", newLink);

            if (response.IsSuccessStatusCode)
            {
                NavigationManager.NavigateTo($"/projects/{Id}");
            }
    }
}
