@page "/ideas/create/{Id:guid}"
@using Planora.Web.Models.DTOs.Idea
@inject NavigationManager NavigationManager
@inject HttpClient Http

<section class="form-layout">
    <div class="form-intro">
        <span class="section-kicker">Pomysł</span>
        <h2>Zapisz nową szansę</h2>
        <p>Dodaj krótki pomysł, żeby można było wrócić do niego bez przerywania bieżącej pracy.</p>
    </div>

    <EditForm Model="newIdea" OnValidSubmit="CreateNewIdea" class="form-card">
        <DataAnnotationsValidator />
        <div class="form-grid">
            <label class="input-control">
                <span>Tytuł pomysłu</span>
                <InputText @bind-Value="newIdea.Title" placeholder="Usprawnić checklistę wdrożenia" />
                <ValidationMessage For="@(() => newIdea.Title)" />
            </label>

            <label class="input-control">
                <span>Opis</span>
                <InputTextArea @bind-Value="newIdea.Description" placeholder="Dlaczego to ważne i co warto sprawdzić" rows="6" />
                <ValidationMessage For="@(() => newIdea.Description)" />
            </label>
        </div>

        <div class="form-actions">
            <a class="btn btn-secondary" href="@($"/projects/{Id}")">Anuluj</a>
            <button class="btn btn-primary" type="submit">Zapisz pomysł</button>
        </div>
    </EditForm>
</section>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private CreateIdeaDto newIdea = new();

    private async Task CreateNewIdea()
    {
        var response = await Http.PostAsJsonAsync($"api/projects/{Id}/ideas", newIdea);

        if (response.IsSuccessStatusCode)
        {
            NavigationManager.NavigateTo($"/projects/{Id}");
        }
    }
}
