@page "/ideas/create/{Id:guid}"
@using Planora.Web.Models.DTOs.Idea
@inject NavigationManager NavigationManager
@inject HttpClient Http

<section class="form-layout">
    <div class="form-intro">
        <span class="section-kicker">Idea</span>
        <h2>Capture an opportunity</h2>
        <p>Save a lightweight idea so it can be reviewed without interrupting active work.</p>
    </div>

    <EditForm Model="newIdea" OnValidSubmit="CreateNewIdea" class="form-card">
        <DataAnnotationsValidator />
        <div class="form-grid">
            <label class="input-control">
                <span>Idea title</span>
                <InputText @bind-Value="newIdea.Title" placeholder="Improve onboarding checklist" />
                <ValidationMessage For="@(() => newIdea.Title)" />
            </label>

            <label class="input-control">
                <span>Description</span>
                <InputTextArea @bind-Value="newIdea.Description" placeholder="Why it matters and what to explore" rows="6" />
                <ValidationMessage For="@(() => newIdea.Description)" />
            </label>
        </div>

        <div class="form-actions">
            <a class="btn btn-secondary" href="@($"/projects/{Id}")">Cancel</a>
            <button class="btn btn-primary" type="submit">Save idea</button>
        </div>
    </EditForm>
</section>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private CreateIdeaDto newIdea = new();

    private async Task CreateNewIdea()
    {
        var response = await Http.PostAsJsonAsync($"api/projects/{Id}/ideas", newIdea);

        if (response.IsSuccessStatusCode)
        {
            NavigationManager.NavigateTo($"/projects/{Id}");
        }
    }
}
