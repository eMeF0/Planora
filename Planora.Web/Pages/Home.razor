@page "/"
@using MudBlazor
@using Planora.Web.Models.DTOs
@using System.Net.Http.Json
@inject HttpClient Http
<MudButton Variant="Variant.Filled" EndIcon="@Icons.Material.Filled.Send" Color="Color.Primary" href="/projects/create">
    Create Project
</MudButton>
<MudGrid>
    @foreach (var project in projects ?? Enumerable.Empty<ProjectSummaryDto>())
    {
        <MudItem xs="12" sm="6" md="4">
            <MudCard>
                <MudCardContent>

                    <MudText Typo="Typo.h5">
                        @project.Name
                    </MudText>

                    <MudText>
                        @project.Description
                    </MudText>

                    <MudChip T="string" Color="Color.Success">
                        @project.Status.ToString()
                    </MudChip>

                </MudCardContent>

                <MudCardActions>
                    <MudButton Color="Color.Primary" Href="@($"/projects/{project.Id}")">
                        Open Project
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    }
</MudGrid>

@code {
    private List<ProjectSummaryDto>? projects;

    protected override async System.Threading.Tasks.Task OnInitializedAsync()
    {
        projects = await Http.GetFromJsonAsync<List<ProjectSummaryDto>>("api/project");
    }
}
