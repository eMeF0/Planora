@page "/"
@using Planora.Web.Models.DTOs
@using System.Net.Http.Json
@inject HttpClient Http

<section class="dashboard-grid">
    <div class="welcome-card">
        <div>
            <span class="section-kicker">Centrum pracy</span>
            <h2>Panel</h2>
            <p>Monitoruj dzisiejsze obciążenie, terminy, aktywność i postęp bez zarządzania projektami z tego widoku.</p>
        </div>
    </div>

    <div class="metric-card">
        <span>Aktywne obszary</span>
        <strong>@ActiveProjects</strong>
        <small>Obszary pracy w toku</small>
    </div>

    <div class="metric-card">
        <span>Nadchodzące terminy</span>
        <strong>@DueSoonProjects</strong>
        <small>Terminy w ciągu 7 dni</small>
    </div>

    <div class="metric-card">
        <span>Ukończone</span>
        <strong>@CompletionRate%</strong>
        <small>Poziom ukończenia</small>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(loadError))
{
    <div class="empty-state">@loadError</div>
}

<section class="dashboard-command-grid">
    <div class="panel panel-large">
        <div class="panel-header">
            <div>
                <span class="section-kicker">Statystyki</span>
                <h2>Podsumowanie aktywności</h2>
            </div>
        </div>

        <div class="insight-grid">
            <div class="insight-row">
                <span>Aktywne</span>
                <strong>@ActiveProjects</strong>
            </div>
            <div class="insight-row">
                <span>Ukończone</span>
                <strong>@CompletedProjects</strong>
            </div>
            <div class="insight-row">
                <span>Po terminie</span>
                <strong>@OverdueProjects</strong>
            </div>
        </div>

        <div class="productivity-chart" aria-label="Wykres produktywności">
            @foreach (var value in ProductivityValues)
            {
                <span style="height: @value%"></span>
            }
        </div>
    </div>

    <div class="panel">
        <div class="panel-header simple">
            <div>
                <span class="section-kicker">Dzisiaj</span>
                <h2>Zadania na dziś</h2>
            </div>
        </div>
        <div class="task-list">
            <article class="task-card compact-task">
                <div class="task-checkbox" aria-hidden="true"></div>
                <div class="task-content">
                    <div class="task-title-row">
                        <h3>Przejrzyj priorytety</h3>
                        <span class="priority-pill priority-medium">Fokus</span>
                    </div>
                    <p></p>
                </div>
            </article>
        </div>
    </div>

    <div class="panel">
        <div class="panel-header simple">
            <div>
                <span class="section-kicker">Terminy</span>
                <h2>Nadchodzące</h2>
            </div>
        </div>
        <div class="activity-list">
            @foreach (var project in UpcomingProjects)
            {
                <div class="activity-row">
                    <span class="activity-dot warning"></span>
                    <span>
                        <strong>@project.Name</strong>
                        <small>@FormatDeadline(project.Deadline)</small>
                    </span>
                </div>
            }
            @if (!UpcomingProjects.Any())
            {
                <div class="empty-state compact">Brak nadchodzących terminów.</div>
            }
        </div>
    </div>

    <div class="panel">
        <div class="panel-header simple">
            <div>
                <span class="section-kicker">Kalendarz</span>
                <h2>Ten tydzień</h2>
            </div>
        </div>
        <div class="calendar-strip" aria-label="Kalendarz tygodniowy">
            @foreach (var day in WeekDays)
            {
                <div class="calendar-day @(day.Date == DateTime.Today ? "is-today" : string.Empty)">
                    <span>@day.ToString("ddd")</span>
                    <strong>@day.Day</strong>
                </div>
            }
        </div>
    </div>

    <div class="panel">
        <div class="panel-header simple">
            <div>
                <span class="section-kicker">Aktywność</span>
                <h2>Ostatnia aktywność</h2>
            </div>
        </div>
        <div class="activity-list">
            @foreach (var project in RecentProjects)
            {
                <div class="activity-row">
                    <span class="activity-dot success"></span>
                    <span>
                        <strong>@project.Name</strong>
                        <small>Utworzono @project.CreatedAt.LocalDateTime.ToString("dd MMM yyyy")</small>
                    </span>
                </div>
            }
            @if (!RecentProjects.Any())
            {
                <div class="empty-state compact">Brak ostatniej aktywności.</div>
            }
        </div>
    </div>
</section>

@code {
    private List<ProjectSummaryDto>? projects;
    private string? loadError;

    private IEnumerable<ProjectSummaryDto> ProjectItems => projects ?? Enumerable.Empty<ProjectSummaryDto>();
    private int ActiveProjects => ProjectItems.Count(project => project.Status == ProjectStatus.Active);
    private int CompletedProjects => ProjectItems.Count(project => project.Status == ProjectStatus.Completed);
    private int OverdueProjects => ProjectItems.Count(project => project.Deadline.HasValue && project.Deadline.Value.LocalDateTime.Date < DateTime.Today && project.Status != ProjectStatus.Completed);
    private int DueSoonProjects => ProjectItems.Count(project => project.Deadline.HasValue && project.Deadline.Value.LocalDateTime.Date <= DateTime.Today.AddDays(7) && project.Deadline.Value.LocalDateTime.Date >= DateTime.Today);
    private int CompletionRate => ProjectItems.Any() ? (int)Math.Round(CompletedProjects * 100.0 / ProjectItems.Count()) : 0;

    private int[] ProductivityValues => new[] { 42, 58, 50, 74, 66, 82, 70 };

    private IEnumerable<DateTime> WeekDays
    {
        get
        {
            var start = DateTime.Today.AddDays(-(int)DateTime.Today.DayOfWeek + 1);
            return Enumerable.Range(0, 7).Select(offset => start.AddDays(offset));
        }
    }

    private IEnumerable<ProjectSummaryDto> UpcomingProjects => ProjectItems
        .Where(project => project.Deadline.HasValue)
        .OrderBy(project => project.Deadline)
        .Take(5);

    private IEnumerable<ProjectSummaryDto> RecentProjects => ProjectItems
        .OrderByDescending(project => project.CreatedAt)
        .Take(5);

    protected override async System.Threading.Tasks.Task OnInitializedAsync()
    {
        try
        {
            projects = await Http.GetFromJsonAsync<List<ProjectSummaryDto>>("api/project");
        }
        catch (Exception)
        {
            loadError = "Nie udało się załadować danych panelu. Sprawdź, czy Planora API i baza danych działają.";
            projects = new List<ProjectSummaryDto>();
        }
    }

    private static string FormatDeadline(DateTimeOffset? deadline)
    {
        return deadline.HasValue ? $"Termin: {deadline.Value.LocalDateTime:dd MMM}" : "Brak terminu";
    }
}
