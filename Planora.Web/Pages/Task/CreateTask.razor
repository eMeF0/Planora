@page "/tasks/create/{Id:guid}"
@using Planora.Web.Models.DTOs.Task
@inject NavigationManager NavigationManager
@inject HttpClient Http

<MudPaper Class="pa-4">
    <MudForm>
        <MudTextField T="string" Label="Task Title" @bind-value="newProject.Title"/>
        <MudTextField T="string" Label="Description" @bind-value="newProject.Description"/>
    </MudForm>
</MudPaper>
<MudDatePicker PickerVariant="PickerVariant.Static" @bind-date="selectedDeadline"/>
<MudButton OnClick="CreateNewProject">
    Create
</MudButton>

@code {
    [Parameter]
    public Guid Id {get;set;}
    private CreateTaskDto newProject = new CreateTaskDto();
    private DateTime? selectedDeadline;

    private async Task CreateNewProject()
    {
        var response = await Http.PostAsJsonAsync($"api/projects/{Id}/tasks", newProject);
        if (response.IsSuccessStatusCode)
        {
            NavigationManager.NavigateTo($"/projects/{Id}");
        }
    }
}
