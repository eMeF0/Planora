@page "/tasks/create/{Id:guid}"
@using Planora.Web.Models.DTOs.Task
@inject NavigationManager NavigationManager
@inject HttpClient Http

<section class="form-layout">
    <div class="form-intro">
        <span class="section-kicker">Nowe zadanie</span>
        <h2>Określ następny krok</h2>
        <p>Dodaj zadanie z wystarczającym kontekstem, żeby można było je sprawnie wykonać.</p>
    </div>

    <EditForm Model="newProject" OnValidSubmit="CreateNewProject" class="form-card">
        <DataAnnotationsValidator />
        <div class="form-grid">
            <label class="input-control">
                <span>Tytuł zadania</span>
                <InputText @bind-Value="newProject.Title" placeholder="Przygotować plan sprintu" />
                <ValidationMessage For="@(() => newProject.Title)" />
            </label>

            <label class="input-control">
                <span>Opis</span>
                <InputTextArea @bind-Value="newProject.Description" placeholder="Kryteria akceptacji, linki i kontekst" rows="5" />
                <ValidationMessage For="@(() => newProject.Description)" />
            </label>

            <label class="input-control">
                <span>Termin</span>
                <input type="date" @bind="selectedDeadline" />
            </label>
        </div>

        <div class="form-actions">
            <a class="btn btn-secondary" href="@($"/projects/{Id}")">Anuluj</a>
            <button class="btn btn-primary" type="submit">Utwórz zadanie</button>
        </div>
    </EditForm>
</section>

@code {
    [Parameter]
    public Guid Id {get;set;}
    private CreateTaskDto newProject = new CreateTaskDto();
    private DateTime? selectedDeadline;

    private async Task CreateNewProject()
    {
        if (selectedDeadline.HasValue)
        {
            newProject.Deadline = new DateTimeOffset(selectedDeadline.Value, TimeSpan.Zero);
        }

        var response = await Http.PostAsJsonAsync($"api/projects/{Id}/tasks", newProject);
        if (response.IsSuccessStatusCode)
        {
            NavigationManager.NavigateTo($"/projects/{Id}");
        }
    }
}
