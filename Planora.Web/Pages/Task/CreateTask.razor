@page "/tasks/create/{Id:guid}"
@using Planora.Web.Models.DTOs.Task
@inject NavigationManager NavigationManager
@inject HttpClient Http

<MudPaper Class="pa-4">
    <MudForm>
        <MudTextField T="string" Label="Title" @bind-value="newProject.Title"/>
        <MudTextField T="string" Label="Description" @bind-value="newProject.Description" />
        <MudTextField T="DateTime?" Label="Deadline" @bind-value="selectedDeadline"/>
    </MudForm>
</MudPaper>
<MudDatePicker PickerVariant="PickerVariant.Static" @bind-date="selectedDeadline" />
<MudButton OnClick="CreateNewProject">
    Create
</MudButton>

@code {
    private CreateTaskDto newProject = new CreateTaskDto();
    private DateTime? selectedDeadline;

    private async Task CreateNewProject()
    {
        if (selectedDeadline.HasValue)
        {
            newProject.Deadline = new DateTimeOffset(selectedDeadline.Value, TimeSpan.Zero);
        }

        var response = await Http.PostAsJsonAsync("api/project", newProject);
        if (response.IsSuccessStatusCode)
        {
            NavigationManager.NavigateTo("/projects");
        }
    }
}
